{
  "extends": ["next/core-web-vitals", "next/typescript", "prettier"],
  "rules": {
    "@typescript-eslint/no-unused-vars": [
      "warn",
      { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }
    ],
    "@typescript-eslint/consistent-type-imports": [
      "warn",
      { "prefer": "type-imports" }
    ]
  },
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    "supabase/migrations/",
    "playwright-report/",
    "test-results/"
  ]
}
